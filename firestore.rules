rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // ─── Helper functions ───────────────────────────────────────────

    function uid() { return request.auth.uid; }
    function isAuthed() { return request.auth != null; }

    // hasUserDoc: true only if the caller has a users/{uid} document
    // (anonymous clients do not). Guards calls to userDoc().
    function hasUserDoc() {
      return isAuthed()
        && exists(/databases/$(db)/documents/users/$(uid()));
    }

    function userDoc() {
      return get(/databases/$(db)/documents/users/$(uid())).data;
    }
    function myOrgId() { return userDoc().orgId; }
    function myRole() { return userDoc().role; }

    function isAdmin() { return hasUserDoc() && myRole() == 'admin'; }
    function isManager() { return hasUserDoc() && myRole() in ['admin', 'manager']; }
    function isOperator() { return hasUserDoc() && myRole() in ['admin', 'manager', 'operator']; }
    function belongsToMyOrg(orgId) { return hasUserDoc() && myOrgId() == orgId; }

    // ─── Organizations ──────────────────────────────────────────────

    match /organizations/{orgId} {
      allow read: if isAuthed();
      allow write: if isAdmin() && belongsToMyOrg(orgId);
    }

    // ─── Branches ───────────────────────────────────────────────────

    match /branches/{branchId} {
      allow read: if isAuthed();
      allow create: if isAdmin() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isAdmin() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Menus ──────────────────────────────────────────────────────

    match /menus/{menuId} {
      allow read: if isAuthed();
      allow create: if isManager() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isManager() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Categories ─────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if isAuthed();
      allow create: if isManager() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isManager() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Products ───────────────────────────────────────────────────

    match /products/{productId} {
      allow read: if isAuthed();
      allow create: if isManager() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isManager() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Tables ─────────────────────────────────────────────────────

    match /tables/{tableId} {
      allow read: if isAuthed();
      allow create: if isManager() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isManager() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Stations ───────────────────────────────────────────────────

    match /stations/{stationId} {
      allow read: if isAuthed() && belongsToMyOrg(resource.data.orgId);
      allow create: if isAdmin() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isAdmin() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Orders ─────────────────────────────────────────────────────
    // Anonymous clients can create and read their own orders.
    // Staff (with user doc) can read/update orders from their org.

    match /orders/{orderId} {
      allow create: if isAuthed();
      allow read: if isAuthed();
      allow update: if belongsToMyOrg(resource.data.orgId);
    }

    // ─── Order Items ────────────────────────────────────────────────
    // Anonymous clients can create items and read them (for tracking).
    // KDS operators can update items assigned to their station.

    match /order_items/{itemId} {
      allow create: if isAuthed();
      allow read: if isAuthed();
      allow update: if belongsToMyOrg(resource.data.orgId)
                    && (isManager()
                        || userDoc().stationId == resource.data.stationId);
    }

    // ─── Users ──────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if uid() == userId
                  || (isManager() && belongsToMyOrg(resource.data.orgId));
      allow create: if isAdmin() && belongsToMyOrg(request.resource.data.orgId);
      allow update, delete: if isAdmin() && belongsToMyOrg(resource.data.orgId);
    }

    // ─── Integrations ───────────────────────────────────────────────
    // NEVER accessible from clients. Only Cloud Functions (Admin SDK).

    match /integrations/{integrationId} {
      allow read, write: if false;
    }

    // ─── Audit Log ──────────────────────────────────────────────────
    // Read-only for managers. Writes only from Cloud Functions.

    match /audit_log/{logId} {
      allow read: if isManager() && belongsToMyOrg(resource.data.orgId);
      allow write: if false;
    }
  }
}
